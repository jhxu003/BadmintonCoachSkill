{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoProcessingJob",
  "type": "object",
  "required": [
    "job_id",
    "source_id",
    "title",
    "platform",
    "url",
    "priority_topics",
    "processing_status",
    "private_paths",
    "public_outputs",
    "model_plan",
    "promotion_policy"
  ],
  "properties": {
    "job_id": { "type": "string" },
    "source_id": { "type": "string" },
    "title": { "type": "string" },
    "platform": { "type": "string" },
    "url": { "type": "string" },
    "priority_topics": { "type": "array", "items": { "type": "string" } },
    "topic_tags": { "type": "array", "items": { "type": "string" } },
    "stroke_tags": { "type": "array", "items": { "type": "string" } },
    "processing_status": { "type": "string" },
    "review_status": { "type": "string" },
    "private_paths": { "type": "object" },
    "public_outputs": { "type": "object" },
    "model_plan": { "type": "object" },
    "promotion_policy": { "type": "string" }
  },
  "additionalProperties": true
}
