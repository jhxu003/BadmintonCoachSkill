{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Diagnosis",
  "type": "object",
  "required": [
    "primary_framework",
    "issues",
    "evidence",
    "confidence",
    "priority_order",
    "training_plan",
    "retest_metrics",
    "missing_evidence",
    "safety_notes"
  ],
  "properties": {
    "coach_id": { "type": "string" },
    "coach_name": { "type": "string" },
    "primary_framework": { "type": "string" },
    "issues": { "type": "array", "items": { "type": "object" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "priority_order": { "type": "array", "items": { "type": "string" } },
    "training_plan": { "type": "array", "items": { "type": "object" } },
    "retest_metrics": { "type": "array", "items": { "type": "string" } },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "safety_notes": { "type": "array", "items": { "type": "string" } },
    "issue_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "issue_id",
          "comparison_phase",
          "student_frame_ids",
          "coach_reference_ids",
          "correction_target",
          "confidence_boundary",
          "status"
        ],
        "properties": {
          "issue_id": { "type": "string" },
          "comparison_phase": { "type": "string" },
          "student_frame_ids": { "type": "array", "items": { "type": "string" } },
          "coach_reference_ids": { "type": "array", "items": { "type": "string" } },
          "correction_target": { "type": "string" },
          "confidence_boundary": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["matched", "insufficient_evidence", "coach_reference_unavailable"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
